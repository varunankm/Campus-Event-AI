{
  "MongoDB": {
    "ConnectionString": "MONGODB_URI_FROM_ENV",
    "DatabaseName": "campusconnect"
  },
  "Jwt": {
    "Key": "JWT_KEY_FROM_ENV",
    "Issuer": "CampusConnectAPI",
    "Audience": "CampusConnectClient",
    "ExpiryHours": 24
  },
  "Gemini": {
    "ApiKey": "GEMINI_API_KEY_FROM_ENV"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
